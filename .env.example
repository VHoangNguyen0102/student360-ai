# LLM: gemini (cloud) or ollama (local)
LLM_PROVIDER=gemini
# Ollama URL: use http://127.0.0.1:11434 when uvicorn runs on your host and Ollama is local.
# When ai-service runs inside Docker Compose with profile local-llm, use http://ollama:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# Gemini (when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_LLM_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# PostgreSQL — same DB as NestJS backend
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/student360

# Redis — same Redis as NestJS BullMQ
REDIS_URL=redis://localhost:6379

# NestJS backend internal calls
BACKEND_URL=http://localhost:3000
BACKEND_INTERNAL_API_KEY=your-internal-api-key

# Service auth (NestJS sends this header when calling student360-ai)
AI_SERVICE_SECRET=your-service-secret

ENV=local
